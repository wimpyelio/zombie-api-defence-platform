{
  "name": "@zad/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./scoring": {
      "import": "./dist/scoring.js",
      "types": "./dist/scoring.d.ts"
    },
    "./state": {
      "import": "./dist/state.js",
      "types": "./dist/state.d.ts"
    },
    "./decommission": {
      "import": "./dist/decommission.js",
      "types": "./dist/decommission.d.ts"
    },
    "./compliance": {
      "import": "./dist/compliance.js",
      "types": "./dist/compliance.d.ts"
    },
    "./vulnerability": {
      "import": "./dist/vulnerability.js",
      "types": "./dist/vulnerability.d.ts"
    },
    "./knowledge-graph": {
      "import": "./dist/knowledge-graph.js",
      "types": "./dist/knowledge-graph.d.ts"
    },
    "./ml-intelligence": {
      "import": "./dist/ml-intelligence.js",
      "types": "./dist/ml-intelligence.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
